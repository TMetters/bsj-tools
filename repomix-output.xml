<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DP Biology IA Batch Tracker</title>
<link rel="stylesheet" href="./bsj-style.css"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
body {
  background: var(--white);
  min-height: 100vh;
  border-left: 4px solid var(--blue);
}

/* ── HEADER ── */
header {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 14px 32px 14px 28px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.logo-mark {
  width: 40px; height: 40px;
  background: var(--blue);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.logo-mark svg { width: 22px; height: 22px; }

.header-text h1 {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1.2;
}

.header-text p {
  font-size: 0.7rem;
  color: var(--muted);
  font-weight: 500;
  margin-top: 2px;
}

.header-right {
  margin-left: auto;
  display: flex;
  align-items: center;
}

.api-input-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 7px 12px;
  transition: border-color 0.2s;
}

.api-input-wrap:focus-within { border-color: var(--blue); }

.api-input-wrap label {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
}

#api-key {
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  width: 220px;
}

#api-key::placeholder { color: #d1d5db; }

.key-status {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #d1d5db;
  flex-shrink: 0;
}

.key-status.ok { background: var(--success); }

/* ── MAIN ── */
main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 36px 32px 80px 28px;
}

/* ── DROP ZONE ── */
.drop-zone {
  border: 2px dashed var(--border);
  border-radius: 20px;
  background: var(--white);
