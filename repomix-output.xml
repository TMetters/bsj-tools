<title>Invest Smarter — Financial Onboarding</title>
<link rel="stylesheet" href="./bsj-style.css"/>
<style>
body {
  background: var(--white);
  min-height: 100vh;
}

/* ── MOBILE HEADER ── */
.mobile-header {
  display: none;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  border-left: 4px solid var(--blue);
  padding: 14px 20px;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 200;
}

.hamburger-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px;
  display: flex;
  align-items: center;
  color: var(--text);
}

.mobile-title {
  font-size: 0.9rem;
  font-weight: 800;
  color: var(--text);
}

/* ── OVERLAY ── */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.2);
  z-index: 299;
}

.sidebar-overlay.open { display: block; }

/* ── LAYOUT ── */
.layout {
  display: flex;
  min-height: 100vh;
}

/* ── SIDEBAR ── */
.sidebar {
  width: 260px;
  background: var(--white);
  border-left: 4px solid var(--blue);
  border-right: 1px solid var(--border);
  position: fixed;
  top: 0; left: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  z-index: 100;
  overflow-y: auto;
}

.sidebar-logo {
  padding: 24px 20px 18px;
  border-bottom: 1px solid var(--border);
}

.logo-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 4px;
}

.logo-mark {
  width: 36px; height: 36px;
  background: var(--blue);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.logo-mark svg { width: 18px; height: 18px; }

.logo-name {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1.2;
}

.logo-sub {
  font-size: 0.68rem;
  font-weight: 500;
  color: var(--muted);
  margin-top: 2px;
  padding-left: 46px;
}

.progress-wrap {
  padding: 14px 20px;
  border-bottom: 1px solid var(--border);
}

.progress-label {
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
}

.progress-bar-outer {
  background: var(--border);
  border-radius: 99px;
  height: 4px;
  overflow: hidden;
}

.progress-bar-inner {
  height: 100%;
  background: var(--blue);
  border-radius: 99px;
  transition: width 0.4s ease;
}

.nav-section {
  padding: 12px 0;
  flex: 1;
}

.nav-section-label {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 0 20px;
  margin-bottom: 4px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 20px;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--muted);
  border-left: 2px solid transparent;
  margin-left: -1px;
}

.nav-item:hover { color: var(--text); background: #fafafa; }

.nav-item.active {
  color: var(--blue);
  background: #f0f9ff;
  border-left-color: var(--blue);
}

.nav-item.completed { color: var(--text); }

.nav-check {
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 1.5px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 10px;
  color: transparent;
  transition: all 0.2s;
}

.nav-item.completed .nav-check {
  background: var(--success);
  border-color: var(--success);
  color: var(--white);
}

.nav-item.active .nav-check {
  border-color: var(--blue);
  background: #e0f2fe;
  color: var(--blue);
}

/* ── CONTENT ── */
.content {
  margin-left: 260px;
  flex: 1;
  min-height: 100vh;
}

.section-page {
  display: none;
  min-height: 100vh;
}

.section-page.active { display: block; }

/* ── HERO ── */
.hero {
  background: var(--white);
  padding: 52px 56px 40px;
  border-bottom: 1px solid var(--border);
}

.section-num {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 12px;
}

.section-title {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1.15;
  margin-bottom: 12px;
  letter-spacing: -0.02em;
}

.section-subtitle {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--muted);
  max-width: 560px;
  line-height: 1.65;
}

/* ── CONTENT BODY ── */
.content-body {
  padding: 40px 56px;
  max-width: 820px;
}

/* ── CARDS ── */
.card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 24px 28px;
  margin-bottom: 20px;
  transition: border-color 0.2s;
}

.card:hover { border-color: var(--blue); }

.card-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.card-body {
  font-size: 0.88rem;
  line-height: 1.75;
  color: var(--muted);
}

.card-body strong { color: var(--text); font-weight: 700; }

/* ── HIGHLIGHT BOXES ── */
.highlight {
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 16px;
  font-size: 0.86rem;
  line-height: 1.65;
  background: var(--white);
  border: 1px solid var(--border);
  color: var(--muted);
}

.highlight-blue  { border-left: 3px solid var(--blue); }
.highlight-gold  { border-left: 3px solid var(--warn); }
.highlight-green { border-left: 3px solid var(--success); }
.highlight-red   { border-left: 3px solid var(--danger); }

.highlight strong { color: var(--text); font-weight: 700; }

/* ── COMPARISON TABLE ── */
.table-wrap {
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 20px;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.84rem;
}

.compare-table th {
  background: #fafafa;
  padding: 10px 14px;
  text-align: left;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--muted);
  border-bottom: 1px solid var(--border);
}

.compare-table td {
  padding: 11px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--muted);
  vertical-align: top;
  font-size: 0.84rem;
}

.compare-table tr:last-child td { border-bottom: none; }
.compare-table tr:hover td { background: #fafafa; }
.compare-table td:first-child { color: var(--text); font-weight: 600; }

/* ── STEP LIST ── */
.step-list { list-style: none; }

.step-item {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}

.step-item:last-child { border-bottom: none; }

.step-num {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--blue);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--white);
  flex-shrink: 0;
  margin-top: 2px;
}

.step-content { flex: 1; }

.step-title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
}

.step-desc {
  font-size: 0.83rem;
  color: var(--muted);
  line-height: 1.65;
}

/* ── QUIZ ── */
.quiz-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 24px 28px;
  margin-bottom: 20px;
}

.quiz-q {
  font-size: 0.98rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 18px;
  line-height: 1.45;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.quiz-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-radius: 10px;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: border-color 0.15s;
  font-size: 0.86rem;
  font-weight: 500;
  color: var(--muted);
}

.quiz-option:hover { border-color: var(--blue); color: var(--text); }
.quiz-option.correct { border-color: #16a34a; background: #f0fdf4; color: #166534; }
.quiz-option.wrong   { border-color: var(--danger); background: #fef2f2; color: #991b1b; }
.quiz-option.disabled { pointer-events: none; opacity: 0.55; }
.quiz-option.disabled.correct,
.quiz-option.disabled.wrong   { opacity: 1; }

.quiz-radio {
  width: 16px; height: 16px;
  border-radius: 50%;
  border: 1.5px solid var(--border);
  flex-shrink: 0;
}

.quiz-feedback {
  margin-top: 12px;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 0.84rem;
  line-height: 1.6;
  display: none;
}

.quiz-feedback.show    { display: block; }
.quiz-feedback.correct { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
.quiz-feedback.wrong   { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

/* ── BOTTOM NAV ── */
.bottom-nav {
  padding: 28px 56px 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--border);
  margin-top: 16px;
}

.btn-nav {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  border-radius: 10px;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
  border: none;
}

.btn-back {
  background: var(--white);
  color: var(--muted);
  border: 1px solid var(--border);
}

.btn-back:hover { border-color: var(--blue); color: var(--text); }

.btn-next {
  background: var(--blue);
  color: var(--white);
}

