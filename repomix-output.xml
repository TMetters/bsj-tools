}

.btn-secondary:hover { border-color: var(--blue); color: var(--text); }

/* ── FILE LIST ── */
.file-list {
  background: var(--white);
  border-radius: 20px;
  border: 1px solid var(--border);
  overflow: hidden;
}

.file-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 13px 20px;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}

.file-item:last-child { border-bottom: none; }
.file-item:hover { background: #fafafa; }

.file-icon {
  width: 30px; height: 30px;
  border: 1px solid var(--border);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 14px;
}

.file-name-input {
  flex: 1;
  background: transparent;
  border: none;
  border-bottom: 1px solid transparent;
  outline: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text);
  padding: 2px 4px;
  transition: border-color 0.2s;
}

.file-name-input:focus { border-bottom-color: var(--blue); }
.file-name-input:disabled { color: var(--muted); }

.file-size {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  color: var(--muted);
  white-space: nowrap;
}

.file-status {
  font-size: 0.72rem;
  font-weight: 700;
  white-space: nowrap;
}

.status-queued  { color: var(--muted); }
.status-running { color: var(--blue); }
.status-done    { color: var(--success); }
.status-error   { color: var(--danger); }

.file-remove {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 18px;
  line-height: 1;
  padding: 2px 5px;
  border-radius: 4px;
  transition: color 0.15s;
}

.file-remove:hover { color: var(--danger); }

/* ── PROGRESS ── */
.progress-wrap { margin: 20px 0 32px; }

.progress-label {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--muted);
  text-align: center;
  margin-bottom: 10px;
}

.progress-bar-outer {
  background: var(--border);
  border-radius: 99px;
  height: 5px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--blue);
  border-radius: 99px;
  transition: width 0.4s ease;
}

/* ── RESULTS ── */
.results-section { margin-top: 40px; }

.export-bar {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 20px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.export-bar-text {
  font-size: 0.85rem;
  color: var(--muted);
  font-weight: 500;
}

.export-bar-text strong { color: var(--text); font-weight: 800; }

.btn-export {
  background: var(--blue);
  color: var(--white);
  border: none;
  border-radius: 8px;
  padding: 9px 20px;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.15s;
  white-space: nowrap;
}

.btn-export:hover { opacity: 0.88; }

/* ── SUMMARY TABLE ── */
.summary-table-wrap {
  background: var(--white);
  border-radius: 20px;
  border: 1px solid var(--border);
  overflow: hidden;
  margin-bottom: 28px;
}

.summary-table-header {
  padding: 18px 24px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border);
}

.tbl-title { font-size: 0.9rem; font-weight: 700; color: var(--text); }
.tbl-avg   { font-size: 0.82rem; font-weight: 700; color: var(--blue); }

table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }

th {
  background: #fafafa;
  font-size: 0.68rem;
  font-weight: 700;
  color: var(--muted);
  padding: 10px 16px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}

tr:last-child td { border-bottom: none; }
tr:hover td { background: #fafafa; }

.score-pill {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 99px;
  min-width: 42px;
  text-align: center;
}

.score-high { background: #dcfce7; color: #166534; }
.score-mid  { background: #fef3c7; color: #92400e; }
.score-low  { background: #fee2e2; color: #991b1b; }

.total-score { font-size: 0.95rem; font-weight: 800; color: var(--text); }
.flag-count  { font-size: 0.78rem; font-weight: 700; color: var(--danger); }

/* ── RESULT CARDS ── */
.result-card {
  background: var(--white);
  border-radius: 20px;
  border: 1px solid var(--border);
  margin-bottom: 20px;
  overflow: hidden;
  transition: border-color 0.2s;
}

.result-card:hover { border-color: var(--blue); }

.result-card-header {
  padding: 18px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border);
}

.result-student { font-size: 1rem; font-weight: 800; color: var(--text); }
.result-total   { font-size: 0.88rem; font-weight: 700; color: var(--blue); }

.result-body { padding: 24px 28px; }

.criteria-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 24px;
}

.criterion-box {
  background: var(--white);
  border: 1px solid var(--border);
  border-left: 3px solid var(--blue);
  border-radius: 12px;
  padding: 14px 16px;
}

.criterion-tag {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}

.criterion-score {
  font-size: 1.7rem;
  font-weight: 800;
  color: var(--blue);
  line-height: 1;
  margin-bottom: 4px;
}

.criterion-score span { font-size: 0.85rem; color: var(--muted); font-weight: 500; }

.criterion-label { font-size: 0.72rem; color: var(--muted); font-weight: 500; }

.result-block { margin-bottom: 20px; }

.result-block-title {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--border);
}

.result-text { font-size: 0.88rem; line-height: 1.75; color: var(--text); }

.flags-list { list-style: none; }

.flag-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 7px 0;
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--danger);
  border-bottom: 1px solid var(--border);
}

.flag-item:last-child { border-bottom: none; }

.flag-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--danger);
  margin-top: 7px;
  flex-shrink: 0;
}

/* ── MANAGEBAC BOX ── */
.managebac-box {
  background: #f8fbfd;
  border: 1px solid var(--border);
  border-left: 3px solid var(--blue);
  border-radius: 12px;
  padding: 16px 20px;
  margin-top: 16px;
}

.managebac-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.copy-btn {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--muted);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  padding: 4px 12px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
}

.copy-btn:hover { border-color: var(--blue); color: var(--text); }

.managebac-text { font-size: 0.88rem; line-height: 1.75; color: var(--text); }

/* ── ANIMATION ── */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(10px); }
  to   { opacity:1; transform:translateY(0); }
}

.result-card { animation: fadeUp 0.3s ease both; }

/* ── RESPONSIVE ── */
@media (max-width: 700px) {
  main { padding: 20px 20px 60px; }
  .criteria-row { grid-template-columns: repeat(2, 1fr); }
  .header-inner { padding: 12px 20px 12px 16px; }
  #api-key { width: 130px; }
  .btn-group { flex-wrap: wrap; }
}
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo-mark">
      <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11 3v11M6 9l5-6 5 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 16v1.5A1.5 1.5 0 003.5 19h15a1.5 1.5 0 001.5-1.5V16" stroke="rgba(255,255,255,0.55)" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="header-text">
      <h1>DP Biology IA Batch Tracker</h1>
      <p>2025 Syllabus · RD · DA · C · E</p>
    </div>
    <div class="header-right">
      <div class="api-input-wrap">
        <label>API Key</label>
        <input type="password" id="api-key" placeholder="sk-ant-api03-..." oninput="checkKey()"/>
        <div class="key-status" id="key-status"></div>
      </div>
    </div>
  </div>
</header>

<main>

  <!-- DROP ZONE -->
  <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()"
       ondragover="dragOver(event)" ondragleave="dragLeave(event)" ondrop="dropFiles(event)">
    <div class="drop-icon">
      <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 4v14M8 12l6-8 6 8" stroke="#0099d6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M4 20v2a2 2 0 002 2h16a2 2 0 002-2v-2" stroke="#0099d6" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
      </svg>
    </div>
    <div class="drop-title">Drop student IA PDFs here</div>
    <div class="drop-sub">Or click to select — multiple PDFs accepted</div>
    <button class="drop-btn bsj-btn bsj-btn-primary" onclick="event.stopPropagation(); document.getElementById('file-input').click()">
      Select PDF Files
    </button>
    <input type="file" id="file-input" accept=".pdf" multiple onchange="addFiles(this.files)"/>
  </div>

  <!-- QUEUE -->
  <div class="queue-section" id="queue-section" style="display:none">
    <div class="section-header">
      <div class="queue-title">
        Upload Queue
        <span class="count-pill" id="queue-count">0</span>
      </div>
      <div class="btn-group">
        <button class="btn-secondary" onclick="clearCompleted()">Clear completed</button>
        <button class="btn-secondary" onclick="clearAll()">Clear all</button>
        <button class="btn-primary bsj-btn bsj-btn-primary" id="grade-btn" onclick="startBatch()" disabled>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Grade All IAs
        </button>
      </div>
    </div>
    <div class="file-list" id="file-list"></div>
  </div>

  <!-- PROGRESS -->
  <div id="progress-section" style="display:none">
    <div class="progress-wrap">
      <div class="progress-label" id="progress-label">Grading...</div>
      <div class="progress-bar-outer">
        <div class="progress-bar" id="progress-bar" style="width:0%"></div>
      </div>
    </div>
  </div>

  <!-- RESULTS -->
  <div class="results-section" id="results-section" style="display:none">

    <div class="export-bar">
      <div class="export-bar-text">
        <strong id="results-count">0</strong> IAs graded · Scores are first-pass AI estimates — apply professional judgement before entering in ManageBac
      </div>
      <button class="btn-export bsj-btn bsj-btn-primary" onclick="exportCSV()">↓ Export CSV</button>
    </div>

    <div class="summary-table-wrap">
      <div class="summary-table-header">
        <span class="tbl-title">Summary — All Students</span>
        <span class="tbl-avg" id="avg-total"></span>
      </div>
      <div style="overflow-x:auto">
        <table id="summary-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>RD /6</th>
              <th>DA /6</th>
              <th>C /6</th>
              <th>E /6</th>
              <th>Total /24</th>
              <th>Flags</th>
            </tr>
          </thead>
          <tbody id="summary-tbody"></tbody>
        </table>
      </div>
    </div>

    <div id="cards-container"></div>

  </div>

</main>

<script>
let files = [];
let results = [];
let isRunning = false;

// ── Helpers ────────────────────────────────────────────────────────────────────
function safeHtml(str) {
  return String(str == null ? '' : str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function csvField(val) {
  return '"' + String(val == null ? '' : val).replace(/"/g, '""') + '"';
}

// ── API Key — localStorage ─────────────────────────────────────────────────────
window.addEventListener('load', () => {
  const saved = localStorage.getItem('anthropic_api_key');
  if (saved) {
    document.getElementById('api-key').value = saved;
    checkKey();
  }
});

function checkKey() {
  const k = document.getElementById('api-key').value.trim();
  if (k) localStorage.setItem('anthropic_api_key', k);
  else localStorage.removeItem('anthropic_api_key');
  const st = document.getElementById('key-status');
  const valid = k.startsWith('sk-ant') && k.length > 20;
  st.className = 'key-status' + (valid ? ' ok' : '');
  updateGradeBtn();
}

function getKey() {
  return document.getElementById('api-key').value.trim();
}

function updateGradeBtn() {
  const btn = document.getElementById('grade-btn');
  const valid = getKey().startsWith('sk-ant') && getKey().length > 20;
  btn.disabled = files.length === 0 || !valid || isRunning;
}

// ── File handling ──────────────────────────────────────────────────────────────
function dragOver(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.add('dragover');
}

function dragLeave(e) {
  document.getElementById('drop-zone').classList.remove('dragover');
}

function dropFiles(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('dragover');
  const dropped = [...e.dataTransfer.files].filter(f => f.type === 'application/pdf');
  addFiles(dropped);
}

function addFiles(newFiles) {
  const arr = Array.isArray(newFiles) ? newFiles : [...newFiles];
  arr.forEach(f => {
    if (!files.find(x => x.file.name === f.name)) {
      const rawName = f.name.replace(/\.pdf$/i, '').replace(/[-_]/g, ' ').replace(/\s+/g, ' ').trim();
      const studentName = rawName.replace(/<[^>]*>/g, '');
      files.push({ file: f, name: studentName, status: 'queued' });
    }
  });
  renderQueue();
  updateGradeBtn();
}

function renderQueue() {
  const section = document.getElementById('queue-section');
  const list = document.getElementById('file-list');
  const count = document.getElementById('queue-count');

  if (files.length === 0) { section.style.display = 'none'; return; }
  section.style.display = 'block';
  count.textContent = files.length;

  list.innerHTML = files.map((f, i) => `
    <div class="file-item" id="file-item-${i}">
      <div class="file-icon">📄</div>
      <input class="file-name-input" type="text" value="${safeHtml(f.name)}"
             onchange="files[${i}].name = this.value"
             placeholder="Student name..." ${f.status !== 'queued' ? 'disabled' : ''}/>
      <span class="file-size">${(f.file.size / 1024).toFixed(0)} KB</span>
      <span class="file-status status-${f.status}">${f.status}</span>
      ${f.status === 'queued' ? `<button class="file-remove" onclick="removeFile(${i})" title="Remove">×</button>` : '<span style="width:24px"></span>'}
    </div>
  `).join('');
}

function removeFile(i) {
  files.splice(i, 1);
  renderQueue();
  updateGradeBtn();
}

function clearAll() {
  files = [];
  renderQueue();
  updateGradeBtn();
}

function clearCompleted() {
  files = files.filter(f => f.status !== 'done' && f.status !== 'error');
  renderQueue();
  updateGradeBtn();
}

// ── PDF → base64 ───────────────────────────────────────────────────────────────
function toBase64(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = () => res(r.result.split(',')[1]);
    r.onerror = () => rej(new Error('Read failed'));
    r.readAsDataURL(file);
  });
}

// ── Grading ────────────────────────────────────────────────────────────────────
async function startBatch() {
  if (isRunning) return;
  isRunning = true;
  updateGradeBtn();

  const toGrade = files.filter(f => f.status === 'queued');
  document.getElementById('progress-section').style.display = 'block';
  document.getElementById('results-section').style.display = 'block';

  for (let i = 0; i < toGrade.length; i++) {
    const f = toGrade[i];
    const idx = files.indexOf(f);
    files[idx].status = 'running';
    renderQueue();

    const pct = Math.round((i / toGrade.length) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-label').textContent = `Grading ${i + 1} of ${toGrade.length}: ${f.name}...`;

    try {
      const b64 = await toBase64(f.file);
      const result = await gradeIA(f.name, b64, getKey());
      result.studentName = f.name;
      results.push(result);
      files[idx].status = 'done';
    } catch(e) {
      files[idx].status = 'error';
      results.push({ studentName: f.name, error: e.message, rd:0, da:0, c:0, e:0, total:0, flags:[], managebac:'', justifications:{} });
    }

    renderQueue();
    renderResults();
  }

  document.getElementById('progress-bar').style.width = '100%';
  document.getElementById('progress-label').textContent = `Grading complete — ${toGrade.length} IAs processed`;
  isRunning = false;
  updateGradeBtn();
}

async function gradeIA(name, pdfBase64, apiKey) {
  const systemPrompt = `You are an experienced IB Biology examiner applying the 2025 DP Biology IA marking criteria at moderation level.

GRADING RULES (non-negotiable):
- Start at 3 (Achieving) for each criterion. Adjust up or down based on explicit evidence only.
- [DA] Cap at 4/6 maximum UNLESS: a named inferential test AND p-values are explicitly stated and interpreted AND STDEV error bars are present and labelled.
- [C] Cap at 3 if conclusion is descriptive only with no statistical reference.
- [E] Award 4+ only if limitations are mechanistically explained with specific paired improvements.
- n ≥ 5 required for any calculation of means.
- Flag: missing error bars, unlabelled axes, no H0/H1, generic limitations, missing MLA 8 references, tables crossing page breaks, scaffold prompts remaining.

You MUST respond with ONLY valid JSON matching this exact structure:
{
  "rd": <integer 1-6>,
  "da": <integer 1-6>,
  "c": <integer 1-6>,
  "e": <integer 1-6>,
  "rd_justification": "<2-3 sentences referencing specific descriptor evidence>",
  "da_justification": "<2-3 sentences>",
  "c_justification": "<2-3 sentences>",
  "e_justification": "<2-3 sentences>",
  "flags": ["<specific issue 1>", "<specific issue 2>"],
  "managebac": "<~150 word ManageBac comment, third person, formal, no 'you' or 'your'>"
}`;

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1500,
      system: systemPrompt,
      messages: [{
        role: 'user',
        content: [{
          type: 'document',
          source: { type: 'base64', media_type: 'application/pdf', data: pdfBase64 }
        }, {
          type: 'text',
          text: `Grade this IBDP Biology Internal Assessment for student: ${name}. Apply all grading rules strictly. Respond with JSON only.`
        }]
      }]
    })
  });

  if (!response.ok) {
    const err = await response.json();
    throw new Error(err.error?.message || `API error ${response.status}`);
  }

  const data = await response.json();
  const text = data.content?.[0]?.text || '';
  const clean = text.replace(/```json|```/g, '').trim();
  const parsed = JSON.parse(clean);

  return {
    rd: parsed.rd || 0,
    da: parsed.da || 0,
    c: parsed.c || 0,
    e: parsed.e || 0,
    total: (parsed.rd||0) + (parsed.da||0) + (parsed.c||0) + (parsed.e||0),
    flags: parsed.flags || [],
    managebac: parsed.managebac || '',
    justifications: {
      rd: parsed.rd_justification || '',
      da: parsed.da_justification || '',
      c: parsed.c_justification || '',
      e: parsed.e_justification || ''
    }
  };
}

// ── Render ─────────────────────────────────────────────────────────────────────
function scorePill(score, max = 6) {
  const pct = score / max;
  const cls = pct >= 0.75 ? 'score-high' : pct >= 0.5 ? 'score-mid' : 'score-low';
  return `<span class="score-pill ${cls}">${score}/${max}</span>`;
}

function criterionLabel(score) {
  if (score >= 5) return 'Proficient';
  if (score >= 3) return 'Achieving';
  if (score >= 1) return 'Developing';
  return '--';
}

function renderResults() {
  document.getElementById('results-count').textContent = results.length;

  const tbody = document.getElementById('summary-tbody');
  tbody.innerHTML = results.map(r => `
    <tr>
      <td><strong>${safeHtml(r.studentName)}</strong></td>
      <td>${scorePill(r.rd)}</td>
      <td>${scorePill(r.da)}</td>
      <td>${scorePill(r.c)}</td>
      <td>${scorePill(r.e)}</td>
      <td><span class="total-score">${r.total}/24</span></td>
      <td><span class="flag-count">${r.flags?.length || 0} flags</span></td>
    </tr>
  `).join('');

  if (results.length > 0) {
    const avg = (results.reduce((s, r) => s + r.total, 0) / results.length).toFixed(1);
    document.getElementById('avg-total').textContent = `Class avg: ${avg}/24`;
  }

  const container = document.getElementById('cards-container');
  container.innerHTML = results.map((r, idx) => `
    <div class="result-card">
      <div class="result-card-header">
        <div class="result-student">${safeHtml(r.studentName)}</div>
        <div class="result-total">Total: ${r.total}/24</div>
      </div>
      <div class="result-body">
        ${r.error
          ? `<div style="color:#dc2626;font-family:'DM Mono',monospace;font-size:0.82rem;padding:12px 0">Error: ${safeHtml(r.error)}</div>`
          : `
        <div class="criteria-row">
          <div class="criterion-box">
            <div class="criterion-tag">RD — Research Design</div>
            <div class="criterion-score">${r.rd}<span>/6</span></div>
            <div class="criterion-label">${criterionLabel(r.rd)}</div>
          </div>
          <div class="criterion-box">
            <div class="criterion-tag">DA — Data Analysis</div>
            <div class="criterion-score">${r.da}<span>/6</span></div>
            <div class="criterion-label">${criterionLabel(r.da)}</div>
          </div>
          <div class="criterion-box">
            <div class="criterion-tag">C — Conclusion</div>
            <div class="criterion-score">${r.c}<span>/6</span></div>
            <div class="criterion-label">${criterionLabel(r.c)}</div>
          </div>
          <div class="criterion-box">
            <div class="criterion-tag">E — Evaluation</div>
            <div class="criterion-score">${r.e}<span>/6</span></div>
            <div class="criterion-label">${criterionLabel(r.e)}</div>
          </div>
        </div>

        <div class="result-block">
          <div class="result-block-title">Criterion Justifications</div>
          <div class="result-text">
            <p style="margin-bottom:8px"><strong>[RD]</strong> ${safeHtml(r.justifications?.rd || '')}</p>
            <p style="margin-bottom:8px"><strong>[DA]</strong> ${safeHtml(r.justifications?.da || '')}</p>
            <p style="margin-bottom:8px"><strong>[C]</strong> ${safeHtml(r.justifications?.c || '')}</p>
            <p><strong>[E]</strong> ${safeHtml(r.justifications?.e || '')}</p>
          </div>
        </div>

        ${r.flags && r.flags.length > 0 ? `
        <div class="result-block">
          <div class="result-block-title">⚑ Flags — Review Before ManageBac Entry</div>
          <ul class="flags-list">
            ${r.flags.map(f => `<li class="flag-item"><span class="flag-dot"></span>${safeHtml(f)}</li>`).join('')}
          </ul>
        </div>` : ''}

        <div class="managebac-box">
          <div class="managebac-label">
            ManageBac Comment (~150 words)
            <button class="copy-btn" onclick="copyText('mb-${idx}', this)">Copy</button>
          </div>
          <div class="managebac-text" id="mb-${idx}">${safeHtml(r.managebac)}</div>
        </div>
        `}
      </div>
    </div>
  `).join('');
}

function copyText(id, btn) {
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });
}

// ── CSV Export ─────────────────────────────────────────────────────────────────
function exportCSV() {
  if (results.length === 0) return;
  const header = ['Student', 'RD', 'DA', 'C', 'E', 'Total', 'Flags', 'ManageBac Comment']
    .map(csvField).join(',');
  const rows = results.map(r => [
    csvField(r.studentName),
    csvField(r.rd),
    csvField(r.da),
    csvField(r.c),
    csvField(r.e),
    csvField(r.total),
    csvField((r.flags || []).join(' | ')),
    csvField(r.managebac || '')
  ].join(','));
  const csv = [header, ...rows].join('\n');
  const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `BSJ_IA_Batch_${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}
</script>
</body>
</html>
